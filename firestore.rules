rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Prevent unauthenticated access globally by default
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Users Collection Rules
    match /users/{userId} {
      // Any authenticated user can read user documents (or restrict if needed)
      allow read: if request.auth != null;
      
      // Allow users to create their own document if it doesn't exist
      // Enforce that new users can only be created with role: 'user'
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.role == 'user';
      
      // Prevent users from updating their own 'role' field
      // Only an existing admin can change roles
      allow update: if request.auth != null 
                    && (
                      (request.auth.uid == userId && request.resource.data.role == resource.data.role)
                      || 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                    );
                    
      allow delete: if request.auth != null 
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Admin-only collections (e.g., shops, disbursements)
    match /shops/{shopId} {
      // Allow read for everyone authenticated, or restrict to admin
      // allow read: if request.auth != null;
      allow read, write: if request.auth != null 
                         && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /disbursements/{disbursementId} {
      allow read, write: if request.auth != null 
                         && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
